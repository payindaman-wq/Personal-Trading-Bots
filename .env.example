# =============================================================================
# crypto-trading-toolkit — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your real values
#   source .env   (or set via systemd / docker / OpenClaw config)
# =============================================================================

# --- Workspace & Paths -------------------------------------------------------
# Root directory of your deployed workspace (where competition/, fleet/, etc. live)
WORKSPACE=/root/.openclaw/workspace

# Root directory of your deployed skills
SKILLS_DIR=/root/.openclaw/skills

# --- Telegram ----------------------------------------------------------------
# Your OpenClaw bot token (from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Your personal Telegram user ID (for DMs from the bot)
TELEGRAM_CHAT_ID=

# --- Exchange: Kraken --------------------------------------------------------
# API key and secret from Kraken (Settings > API > Generate Key)
# Required permissions: Query Funds, Create & Modify Orders, Cancel & Close Orders
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# --- OpenRouter (optional — for strategy analysis) ---------------------------
# API key from openrouter.ai (used by SYN for strategy generation / analysis)
OPENROUTER_API_KEY=

# --- GitHub ------------------------------------------------------------------
# Personal access token for pushing to your private deployment repo
# Scopes needed: repo (full)
GITHUB_PAT=

# --- Trading Parameters (optional overrides) ---------------------------------
# Starting capital for each paper trading competition (default: 10000)
# STARTING_CAPITAL=10000

# Exchange fee rate per trade (default: 0.001 = 0.1%)
# FEE_RATE=0.001

# --- Accounting --------------------------------------------------------------
# Tax reserve percentage of realized gains (default: 0.30 = 30%)
# TAX_RESERVE_PCT=0.30

# Operating reserve percentage (default: 0.10 = 10%)
# OPERATING_RESERVE_PCT=0.10

# Estimated federal tax bracket for short-term gains (default: 0.37 = 37%)
# DEFAULT_TAX_RATE=0.37
